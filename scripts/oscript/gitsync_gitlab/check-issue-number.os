#Использовать gitsync

Перем ПараметрыGitLab; // Структура - параметры GitLab

Процедура ПроверитьНомерЗадачи(ПараметрыПроверки, ТекстСообщения) Экспорт
    
    Сообщения = Новый Массив;
    Сообщения.Добавить(ТекстСообщения);
    
    ТекстОшибки = "";
    
    Шаблон = "#(\d+)";
    
    РегулярноеВыражение = Новый РегулярноеВыражение(Шаблон);
    Совпадение = РегулярноеВыражение.НайтиСовпадения(ПараметрыПроверки.Комментарий);
    Если Совпадение.Количество() = 0 Тогда
        ТекстОшибки = "!!! В КОММЕНТАРИИ НЕ УКАЗАНЫ НОМЕРА ЗАДАЧ";
    Иначе
        НомераЗадач = Новый Массив;
        Для Каждого ЭлементСовпадение Из Совпадение Цикл
            НомерЗадачи = СтрЗаменить(ЭлементСовпадение.Значение, "#", "");
            НомераЗадач.Добавить(НомерЗадачи);   
        КонецЦикла;
        ПараметрыПроверки.Вставить("НомераЗадач", НомераЗадач);
        ТекстОшибки = ПроверитьЗадачиGitLab(ПараметрыПроверки);
    КонецЕсли;

    Сообщения.Добавить(ТекстОшибки);
    ТекстСообщения = СтрСоединить(Сообщения, Символы.ПС);
    
КонецПроцедуры

// Функция ПроверитьЗадачи(ПараметрыЗапроса, НомераЗадач)

