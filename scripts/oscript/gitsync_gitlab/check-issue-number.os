// КонецФункции
        
Функция ПроверитьЗадачиGitLab(ПараметрыПроверки)
    
    Ошибки = Новый Массив;

    Соединение = Новый HTTPСоединение(ПараметрыПроверки.АдресСервера,,,,, 
        ПараметрыПроверки.Таймаут);
    
    Заголовки = Новый Соответствие;
    Заголовки.Вставить("PRIVATE-TOKEN", ПараметрыПроверки.ТокенАпи);
    
    ПараметрыЗапроса = Новый Массив;
    Для Каждого НомерЗадачи Из ПараметрыПроверки.НомераЗадач Цикл
        ПараметрыЗапроса.Добавить(СтрШаблон("iids[]=%1", НомерЗадачи));
    КонецЦикла;

    ТекстПараметров = СтрСоединить(ПараметрыЗапроса, "&");

    АдресРесурсаШаблон = "api/v4/projects/%1/issues?%2";
    АдресРесурса = СтрШаблон(АдресРесурсаШаблон, ПараметрыПроверки.IDПроекта, ТекстПараметров);
    ЗапросHTTP = Новый HTTPЗапрос(АдресРесурса, Заголовки);
    
    НайденныеНомераЗадач = Новый Массив;
    Ответ = Соединение.Получить(ЗапросHTTP);
    Если Ответ.КодСостояния = 200 Тогда
        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
        СписокЗадач = ПрочитатьJSON(Чтение);
        
        Для Каждого ЭлементЗадача Из СписокЗадач Цикл
            НайденныеНомераЗадач.Добавить(Строка(ЭлементЗадача.iid));
        КонецЦикла;
    КонецЕсли;

    Для Каждого НомерЗадачи Из ПараметрыПроверки.НомераЗадач Цикл
        Если НайденныеНомераЗадач.Найти(НомерЗадачи) = Неопределено Тогда
            ТекстОшибки = "!!! В ТЕКУЩИЕ ПРОЕКТЕ НЕ НАЙДЕНО ЗАДАЧИ С НОМЕРОМ " + НомерЗадачи;
            Ошибки.Добавить(ТекстОшибки);        
        КонецЕсли;
    КонецЦикла;
    
    Возврат СтрСоединить(Ошибки, Символы.ПС);

КонецФункции
        
